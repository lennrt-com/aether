# Convex — also set WORKER_KEY, AETHER_API_KEY, AETHER_WEBHOOK_SECRET in the Convex dashboard
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=
WORKER_KEY=

# Public HTTP API (POST /v1/jobs, GET /v1/jobs/:id)
AETHER_API_KEY=
# Optional global HMAC secret for webhook signatures (per-job webhookSecret overrides)
AETHER_WEBHOOK_SECRET=
# Optional default webhook URL for interactive `pnpm aether` / `aether run` wizard
# AETHER_DEFAULT_WEBHOOK_URL=https://webhook.site/your-uuid

# Admin dashboard (Convex Auth allowlist — comma-separated emails)
ALLOWED_ADMIN_EMAILS=

# LLM (Stagehand agent)
GOOGLE_GENERATIVE_AI_API_KEY=
# ANTHROPIC_API_KEY=                 # required for claude-opus-4-8 / claude-sonnet-4-6
# AGENT_MODEL=gemini-3-flash-preview # default agent model
# PERSONA_MODEL=gemini-3-flash-preview

# Chrome
CHROME_EXECUTABLE_PATH=
PINNED_CHROME_VERSION=
# WEBRTC_IP_POLICY=disable_non_proxied_udp

# Proxy pool — `aether proxy add|list|remove`
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
DEFAULT_GEO=US
DEFAULT_TZ=UTC

# Worker
WORKER_NAME=local-1
MAX_SESSIONS=2
PROFILES_DIR=./.profiles

# Vaultwarden / Bitwarden CLI (worker resolves bw:Item/field secret refs)
# BW_SERVER_URL=https://vault.example.com
# BW_CLIENTID=                    # personal API key client_id (bw login --apikey)
# BW_CLIENTSECRET=                # personal API key client_secret
# BW_PASSWORD=                    # master password for bw unlock
# BW_SESSION=                     # optional pre-unlocked session (skips unlock)

# CapSolver (captcha tool)
CAPSOLVER_API_KEY=
# CAPSOLVER_USE_BROWSER_PROXY=false

# Optional email / phone tools (agent payload tools: email, phone)
SMTP_DEV_API_KEY=
SMTP_DEV_DOMAIN=
FIVE_SIM_API_KEY=
# FIVE_SIM_PRODUCT=any

# Docker worker defaults
HEADLESS=false

# --- CLI --------------------------------------------------------------------
#   pnpm aether <command>
#   pnpm aether run --start-url ... --instructions ... --webhook-url ...
#   pnpm aether mcp add              # register MCP servers (Bitwarden, Gmail, …)
#   pnpm link-cli    # install global `aether` shim

# --- VPS --------------------------------------------------------------------
# docker compose up -d --build
