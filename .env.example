# Convex — also set WORKER_KEY and UNIPILE_WEBHOOK_SECRET in the Convex dashboard
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=
WORKER_KEY=

# LLM (Stagehand + persona generation)
GOOGLE_GENERATIVE_AI_API_KEY=
# ANTHROPIC_API_KEY=                 # required for claude-opus-4-8 / claude-sonnet-4-6 agent models
# AGENT_MODEL=gemini-3-flash-preview # default agent model (gemini-3-flash-preview | claude-opus-4-8 | claude-sonnet-4-6)
# PERSONA_MODEL=gemini-3-flash-preview # persona generation model (same choices as agent)
# ANTHROPIC_API_KEY=                 # required for claude persona/agent models

# Chrome
CHROME_EXECUTABLE_PATH=
PINNED_CHROME_VERSION=
# WebRTC IP handling policy — replaces the "WebRTC Network Limiter" extension so
# WebRTC can't leak the real IP past the proxy over UDP. Applied via launch flags
# + seeded into the profile Preferences. One of: default,
# default_public_and_private_interfaces, default_public_interface_only,
# disable_non_proxied_udp. Defaults to disable_non_proxied_udp; set to "default"
# to disable WebRTC hardening entirely.
# WEBRTC_IP_POLICY=disable_non_proxied_udp

# Coronium proxy — persistent pool managed via `bless proxy add|list|remove`
# Legacy single-proxy env vars still work as CLI fallbacks for launch/agent-test.
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
# PROXY_BYPASS=

# Worker
WORKER_NAME=local-1
MAX_SESSIONS=2
PROFILES_DIR=./.profiles

# Unipile v2 (phase 8) — api.unipile.com + X-API-KEY, no DSN
UNIPILE_API_KEY=
UNIPILE_WEBHOOK_SECRET=
# UNIPILE_BASE_URL=https://api.unipile.com

# smtp.dev (account creation) — REST API, X-API-KEY auth.
# SMTP_DEV_DOMAIN must be added at smtp.dev with MX -> mx.smtp.dev
SMTP_DEV_API_KEY=
SMTP_DEV_DOMAIN=
# SMTP_DEV_BASE_URL=https://api.smtp.dev

# CapSolver (reCAPTCHA solving) — https://dashboard.capsolver.com
CAPSOLVER_API_KEY=
# CAPSOLVER_BASE_URL=https://api.capsolver.com
# CapSolver runs on their servers — do NOT pass your Coronium/browser proxy unless it
# accepts inbound connections from CapSolver's cloud (most residential proxies don't).
# Default: ReCaptchaV2TaskProxyLess (CapSolver's own IPs). Set true only for proxies
# CapSolver can reach directly (e.g. datacenter with no IP whitelist).
# CAPSOLVER_USE_BROWSER_PROXY=false
# CAPSOLVER_PROXY_TYPE=http              # http | https | socks5 — when USE_BROWSER_PROXY=true

# 5sim (phone/SMS verification) — https://5sim.net/docs — Bearer JWT from profile settings
FIVE_SIM_API_KEY=
# FIVE_SIM_BASE_URL=https://5sim.net
# FIVE_SIM_COUNTRY=england          # override profile geo → 5sim country slug (usa, germany, …)
# FIVE_SIM_OPERATOR=any             # operator or any
# FIVE_SIM_PRODUCT=linkedin         # service name at 5sim

# LinkedIn signup entry point
# LINKEDIN_SIGNUP_URL=https://www.linkedin.com/signup
# SIGNUP_FEED_WARMUP_MS=30000         # feed scroll duration after onboarding (default 30s)

# Hindsight (deferred — stub until HTTP API is wired)
# HINDSIGHT_API_URL=
# HINDSIGHT_API_KEY=

# --- CLI --------------------------------------------------------------------
# Run from project root:
#   pnpm bless <command>          e.g. pnpm bless create, pnpm bless reset --yes
#   .\bless <command>             Windows (bless.cmd / bless.ps1 in repo root)
# One-time global install (then `bless` works after PATH refresh or new terminal):
#   pnpm link-cli
#   pnpm refresh-path    # reload PATH in current PowerShell without reopening

START_URL=https://example.com
AGENT_INSTRUCTION=
MAX_STEPS=15
HEADLESS=false

# Pre-signup proxy/fingerprint gate (runs before LinkedIn on signup tasks)
# PREFLIGHT=false                     # disable the gate entirely
# PREFLIGHT_STRICT=false              # don't abort when too many checks are unverifiable
# PREFLIGHT_PROXY_RISK_THRESHOLD=75   # IPQS-style fraud score that counts as suspicious
# PREFLIGHT_FINGERPRINT=true          # run Fingerprint scanner visitorId check on signup
# FINGERPRINT_SPOOF=true              # inject per-profile canvas/WebGL/audio noise
# FINGERPRINT_SCANNER_URL=https://anti-detect-scanner-production.up.railway.app/
# FINGERPRINT_SCANNER_SETTLE_MS=8000  # wait after scanner navigation before extract
# FINGERPRINT_API_KEY=                # Fingerprint Server API secret (Auth-API-Key)
# FINGERPRINT_API_BASE=https://api.fpjs.io

# --- manual launch (`bless launch`) -----------------------------------------
# MANUAL_START_URL=                   # default landing page for manual sessions
#                                     # (falls back to FINGERPRINT_SCANNER_URL)

# --- Stagehand CDP stealth patch (Phase 1) ----------------------------------
# @browserbasehq/stagehand is patched via patches/@browserbasehq__stagehand@3.5.0.patch
# Removes persistent Runtime.enable so fingerprint.com developer_tools/bot checks
# pass at page load. Re-run `pnpm install` after editing the patch file.
